    {
      messaging_product: "whatsapp",
      to,
      type: "interactive",
      interactive: {
        type: "list",
        header: { type: "text", text: header },
        body: { text: body },
        footer: { text: BUSINESS_NAME },
        action: { button, sections: [{ title: sectionTitle, rows }] },
